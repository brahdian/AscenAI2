# =============================================================================
# AscenAI — Environment Variables
# Copy this file to .env and fill in your values.
# Generate secrets with: openssl rand -hex 32
# =============================================================================

# ---------------------------------------------------------------------------
# Security (REQUIRED — must be strong random values in production)
# ---------------------------------------------------------------------------
SECRET_KEY=change-this-to-a-random-32-char-string-in-production

# ---------------------------------------------------------------------------
# Database credentials
# ---------------------------------------------------------------------------
# Local dev: use the defaults. Production: set strong credentials.
POSTGRES_USER=ascenai
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=ascenai

# Full connection URLs (auto-built from above in docker-compose; override if using managed DB)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ---------------------------------------------------------------------------
# LLM Provider (pick one)
# ---------------------------------------------------------------------------
LLM_PROVIDER=gemini           # "gemini" | "openai" | "vertex"

# Gemini (recommended — fastest/cheapest for voice + chat)
GEMINI_API_KEY=               # Required if LLM_PROVIDER=gemini
# gemini-2.5-flash-lite-preview-06-17  ← default (cheapest, 25 tok/sec)
# gemini-2.5-flash                     ← better quality, ~3× cost
# gemini-2.5-pro                       ← highest quality, ~10× cost
GEMINI_MODEL=gemini-2.5-flash-lite-preview-06-17

# OpenAI (fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Vertex AI — uses Application Default Credentials (ADC), no API key needed.
# Run: gcloud auth application-default login  before starting services.
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# ---------------------------------------------------------------------------
# Voice (optional)
# ---------------------------------------------------------------------------
STT_PROVIDER=openai           # "openai" | "deepgram"
TTS_PROVIDER=openai           # "openai" | "elevenlabs"
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ---------------------------------------------------------------------------
# Stripe (for in-product payment links via Stripe tool)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Email / SMTP (for auth emails and the Gmail tool)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@yourdomain.com

# ---------------------------------------------------------------------------
# Twilio (for SMS tool)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---------------------------------------------------------------------------
# Frontend & CORS
# ---------------------------------------------------------------------------
# In production: set to your actual domain
DOMAIN=yourdomain.com
FRONTEND_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXT_PUBLIC_WS_URL=wss://yourdomain.com

# List of origins allowed to call the API (JSON array, no spaces)
ALLOWED_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Qdrant (vector DB for RAG)
# ---------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ---------------------------------------------------------------------------
# Document storage
# ---------------------------------------------------------------------------
# Mount a persistent volume at this path in production
DOCUMENT_STORAGE_PATH=/data/documents

# ---------------------------------------------------------------------------
# Observability (all optional but recommended in production)
# ---------------------------------------------------------------------------
ENVIRONMENT=production        # "development" | "staging" | "production"
DEBUG=false

# Sentry — error tracking
SENTRY_DSN=

# OpenTelemetry — distributed tracing (Jaeger, Grafana Tempo, Honeycomb, etc.)
OTEL_ENABLED=false
OTEL_ENDPOINT=                # OTLP HTTP endpoint e.g. http://otel-collector:4318

# Prometheus — metrics exposed at /metrics on each service (always enabled, no config needed)

# ---------------------------------------------------------------------------
# Uvicorn workers (set in docker-compose.prod.yml; documented here for reference)
# ---------------------------------------------------------------------------
# WORKERS=4    ← for api-gateway (CPU-bound: set to 2× CPU cores)
# WORKERS=2    ← for mcp-server, ai-orchestrator, voice-pipeline

# Orchestration safety limits (ai-orchestrator)
# ---------------------------------------------------------------------------
# LLM_TIMEOUT_SECONDS=30          # Hard timeout per LLM call (TC-F02)
# MAX_TOOL_ITERATIONS=3           # Max tool-call loop iterations per turn (TC-D04)
# FALLBACK_ESCALATION_THRESHOLD=3 # Auto-escalate after N consecutive fallbacks (TC-C03)
