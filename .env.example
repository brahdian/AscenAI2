# =============================================================================
# AscenAI — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Security (REQUIRED — generate strong random values)
# -----------------------------------------------------------------------------
SECRET_KEY=change-this-to-a-random-32-char-string-in-production

# -----------------------------------------------------------------------------
# LLM Provider (pick one)
# -----------------------------------------------------------------------------
LLM_PROVIDER=gemini           # "gemini" or "openai"
GEMINI_API_KEY=               # Required if LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash-lite

OPENAI_API_KEY=               # Required if LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Voice (optional)
# -----------------------------------------------------------------------------
STT_PROVIDER=openai           # "openai" or "deepgram"
TTS_PROVIDER=openai           # "openai" or "elevenlabs"
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# -----------------------------------------------------------------------------
# Stripe (optional — for billing)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Email / SMTP (optional — for welcome emails and password reset)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@ascenai.com

# -----------------------------------------------------------------------------
# Twilio (optional — for SMS tool)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8002

# -----------------------------------------------------------------------------
# Infrastructure (populated automatically by docker-compose; override for prod)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ascenai
REDIS_URL=redis://redis:6379/0
QDRANT_HOST=qdrant
QDRANT_PORT=6333
