# =============================================================================
# AscenAI — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Security (REQUIRED — generate strong random values)
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
REDIS_PASSWORD=CHANGE_ME_strong_random_password

# -----------------------------------------------------------------------------
# LLM Provider (pick one)
# -----------------------------------------------------------------------------
LLM_PROVIDER=gemini           # "gemini" | "openai" | "vertex"
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

OPENAI_API_KEY=               # Required if LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# Vertex AI — API-key auth (set LLM_PROVIDER=vertex to activate)
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_API_KEY=your-vertex-api-key
VERTEX_API_ENDPOINT=https://aiplatform.googleapis.com/v1/publishers/google/models

# -----------------------------------------------------------------------------
# Voice (optional)
# -----------------------------------------------------------------------------
STT_PROVIDER=cartesia            # "openai", "deepgram", or "cartesia"
TTS_PROVIDER=cartesia            # "openai", "elevenlabs", or "cartesia"
CARTESIA_API_KEY=your-cartesia-api-key
DEEPGRAM_API_KEY=your-deepgram-api-key
ELEVENLABS_API_KEY=

# -----------------------------------------------------------------------------
# Stripe (optional — for billing)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# -----------------------------------------------------------------------------
# Email / SMTP (optional — for welcome emails and password reset)
# -----------------------------------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_TLS=false
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@ascenai.com

# -----------------------------------------------------------------------------
# Twilio (optional — for SMS tool)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
FRONTEND_URL=http://app.lvh.me:3000
NEXT_PUBLIC_API_URL=http://api.lvh.me:8000
NEXT_PUBLIC_WS_URL=ws://api.lvh.me:8000

# Domain routing — used by Next.js middleware and admin portal
# In production, replace these with your actual domain (e.g., ascenai.com, admin.ascenai.com)
NEXT_PUBLIC_ROOT_DOMAIN=lvh.me:3000
NEXT_PUBLIC_ADMIN_SUBDOMAIN=admin.lvh.me:3000
NEXT_PUBLIC_APP_NAME=AscenAI
COOKIE_DOMAIN=.lvh.me
DYNAMIC_COOKIE_DOMAIN=true
ALLOWED_ORIGINS=http://lvh.me:3000,http://admin.lvh.me:3000,http://app.lvh.me:3000,http://localhost:3000

# -----------------------------------------------------------------------------
# Observability (all optional)
# -----------------------------------------------------------------------------
# Sentry — error tracking
SENTRY_DSN=
ENVIRONMENT=development        # "development" | "staging" | "production"

# OpenTelemetry — distributed tracing (e.g. Jaeger, Grafana Tempo, Honeycomb)
OTEL_ENABLED=false
OTEL_ENDPOINT=                # OTLP HTTP endpoint, e.g. http://jaeger:4318

# Prometheus — metrics exposed at /metrics on each service (always enabled)

# -----------------------------------------------------------------------------
# Infrastructure (populated automatically by docker-compose; override for prod)
# -----------------------------------------------------------------------------
POSTGRES_USER=ascenai
POSTGRES_DB=ascenai
DATABASE_URL=postgresql+asyncpg://ascenai:postgres@postgres:5432/ascenai
# Use rediss:// (TLS) in production — matches the HIGH-6/M-8 docker-compose.prod.yml Redis config
REDIS_URL=redis://:CHANGE_ME_strong_random_password@redis:6379/0
# REDIS_URL=rediss://:CHANGE_ME_strong_random_password@redis:6380/0  # production TLS
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# -----------------------------------------------------------------------------
# PII Pseudonymization
# -----------------------------------------------------------------------------
PII_PSEUDO_DOMAIN=ascenai.private

# Stripe Price IDs (auto-generated)
STRIPE_TEXT_GROWTH_PRODUCT_ID=prod_UFIvyn7Ck9LyyC
STRIPE_TEXT_GROWTH_PRICE_ID=price_1TGoJXL2CfYNtGlX1t9Yned1
STRIPE_VOICE_GROWTH_PRODUCT_ID=prod_UFIvm4VMUYaigm
STRIPE_VOICE_GROWTH_PRICE_ID=price_1TGoJXL2CfYNtGlXlIvxbaEc
STRIPE_VOICE_BUSINESS_PRODUCT_ID=prod_UFIv1vSEn0jEkq
STRIPE_VOICE_BUSINESS_PRICE_ID=price_1TGoJYL2CfYNtGlXcGBty9q0
